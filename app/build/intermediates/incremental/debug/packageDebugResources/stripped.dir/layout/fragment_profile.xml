<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/park_gray">

    <!-- Header -->
    <LinearLayout android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/park_navy"
        android:orientation="vertical"
        android:padding="18dp">
        <LinearLayout android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">
            <TextView android:id="@+id/tvAvatarInitials"
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:gravity="center"
                android:textColor="@color/white"
                android:textSize="20sp"
                android:textStyle="bold"
                android:background="@color/park_red" />
            <LinearLayout android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginStart="14dp">
                <TextView android:id="@+id/tvUserName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/white"
                    android:textSize="16sp"
                    android:textStyle="bold" />
                <TextView android:id="@+id/tvUserEmail"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#80FFFFFF"
                    android:textSize="12sp" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <ScrollView android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">
        <LinearLayout android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Податоци за корисник -->
            <TextView android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ПОДАТОЦИ ЗА КОРИСНИК"
                android:textColor="@color/park_text_tertiary"
                android:textSize="11sp"
                android:letterSpacing="0.08"
                android:layout_marginBottom="8dp" />

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="14dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@color/white"
                android:layout_marginBottom="14dp">
                <LinearLayout android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- Ime -->
                    <LinearLayout android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:paddingHorizontal="16dp"
                        android:paddingVertical="12dp">
                        <TextView android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Ime и презиме"
                            android:textSize="12sp"
                            android:textColor="@color/park_text_secondary" />
                        <TextView android:id="@+id/tvProfileName"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:textColor="@color/park_navy" />
                    </LinearLayout>

                    <View android:layout_width="match_parent"
                        android:layout_height="0.5dp"
                        android:background="@color/park_border" />

                    <!-- Email -->
                    <LinearLayout android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:paddingHorizontal="16dp"
                        android:paddingVertical="12dp">
                        <TextView android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Е-пошта"
                            android:textSize="12sp"
                            android:textColor="@color/park_text_secondary" />
                        <TextView android:id="@+id/tvProfileEmail"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:textColor="@color/park_navy" />
                    </LinearLayout>

                    <View android:layout_width="match_parent"
                        android:layout_height="0.5dp"
                        android:background="@color/park_border" />

                    <!-- Телефон -->
                    <LinearLayout android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:paddingHorizontal="16dp"
                        android:paddingVertical="12dp">
                        <TextView android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Телефон"
                            android:textSize="12sp"
                            android:textColor="@color/park_text_secondary" />
                        <TextView android:id="@+id/tvProfilePhone"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:textColor="@color/park_navy" />
                    </LinearLayout>

                    <View android:layout_width="match_parent"
                        android:layout_height="0.5dp"
                        android:background="@color/park_border" />

                    <!-- SMS -->
                    <LinearLayout android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:paddingHorizontal="16dp"
                        android:paddingVertical="12dp">
                        <TextView android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"

                            android:textSize="12sp"
                            android:textColor="@color/park_text_secondary" />
                        <TextView android:layout_width="wrap_content"
                            android:layout_height="wrap_content"

                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:textColor="@color/park_red" />
                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Возила -->
            <TextView android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="МОИ ВОЗИЛА"
                android:textColor="@color/park_text_tertiary"
                android:textSize="11sp"
                android:letterSpacing="0.08"
                android:layout_marginBottom="8dp" />

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="14dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@color/white"
                android:layout_marginBottom="14dp">
                <LinearLayout android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rvVehicles"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:nestedScrollingEnabled="false" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnAddVehicle"
                        style="@style/Widget.MaterialComponents.Button.TextButton"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:text="+ Додај ново возило"
                        android:textColor="@color/park_red"
                        android:textSize="14sp"
                        app:icon="@drawable/ic_add_circle"
                        app:iconTint="@color/park_red" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>
            <!-- Јазик -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnLanguage"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:text="🌐  Јазик / Language"
                android:textColor="@color/park_navy"
                android:layout_marginBottom="10dp"
                app:strokeColor="@color/park_border" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnLogout"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:text="Одјави се"
                android:textColor="@color/park_red"
                app:strokeColor="@color/park_red" />

        </LinearLayout>
    </ScrollView>
</LinearLayout>