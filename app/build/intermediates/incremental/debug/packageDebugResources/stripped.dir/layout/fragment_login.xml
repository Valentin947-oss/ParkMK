<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FF1A1A2E"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Back + Title -->
        <LinearLayout android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="28dp">
            <ImageButton android:id="@+id/btnBack"
                android:layout_width="36dp" android:layout_height="36dp"
                android:background="#20FFFFFF"
                android:src="@drawable/ic_arrow_back"
                android:tint="@color/white"
                android:contentDescription="Back" />
            <LinearLayout android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginStart="12dp">
                <TextView android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/login_title"
                    android:textColor="@color/white"
                    android:textSize="18sp" android:textStyle="bold" />
                <TextView android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/login_subtitle"
                    android:textColor="#80FFFFFF" android:textSize="13sp" />
            </LinearLayout>
        </LinearLayout>

        <!-- Email -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilEmail"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:hint="@string/login_email_hint"
            app:boxStrokeColor="@color/park_red"
            app:hintTextColor="#80FFFFFF"
            app:boxBackgroundColor="#15FFFFFF">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etEmail"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:inputType="textEmailAddress"
                android:textColor="@color/white" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Password -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilPassword"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:hint="@string/login_password_hint"
            app:boxStrokeColor="@color/park_red"
            app:hintTextColor="#80FFFFFF"
            app:boxBackgroundColor="#15FFFFFF"
            app:passwordToggleEnabled="true"
            app:passwordToggleTint="#80FFFFFF">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etPassword"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:inputType="textPassword"
                android:textColor="@color/white" />
        </com.google.android.material.textfield.TextInputLayout>

        <TextView android:id="@+id/tvForgotPassword"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:layout_gravity="end" android:layout_marginTop="8dp"
            android:text="@string/login_forgot_password"
            android:textColor="#80FFFFFF" android:textSize="13sp" android:padding="4dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnLogin"
            android:layout_width="match_parent" android:layout_height="52dp"
            android:layout_marginTop="16dp"
            android:backgroundTint="@color/park_red"
            android:text="@string/login_button"
            android:textColor="@color/white" />

        <!-- Divider -->
        <LinearLayout android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginVertical="18dp">
            <View android:layout_width="0dp" android:layout_height="0.5dp"
                android:layout_weight="1" android:background="#30FFFFFF" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="@string/login_or_divider"
                android:textColor="#50FFFFFF" android:textSize="13sp"
                android:layout_marginHorizontal="12dp" />
            <View android:layout_width="0dp" android:layout_height="0.5dp"
                android:layout_weight="1" android:background="#30FFFFFF" />
        </LinearLayout>

        <!-- Google -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnGoogle"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="match_parent" android:layout_height="50dp"
            android:text="@string/login_with_google"
            android:textColor="@color/white"
            android:layout_marginBottom="10dp"
            app:strokeColor="#40FFFFFF" />

        <!-- Facebook -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnFacebook"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="match_parent" android:layout_height="50dp"
            android:text="@string/login_with_facebook"
            android:textColor="@color/white"
            android:layout_marginBottom="10dp"
            app:strokeColor="#40FFFFFF" />

        <!-- Anonymous -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnAnonymous"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="match_parent" android:layout_height="46dp"
            android:text="@string/welcome_continue_anonymous"
            android:textColor="#70FFFFFF" android:textSize="13sp"
            app:strokeColor="#30FFFFFF" />

        <ProgressBar android:id="@+id/progressBar"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:layout_gravity="center" android:layout_marginTop="12dp"
            android:visibility="gone" />

        <LinearLayout android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginTop="20dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="@string/login_no_account"
                android:textColor="#60FFFFFF" android:textSize="13sp" />
            <TextView android:id="@+id/tvRegister"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="@string/welcome_register"
                android:textColor="@color/park_red"
                android:textSize="13sp" android:textStyle="bold"
                android:layout_marginStart="4dp" android:padding="4dp" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>
