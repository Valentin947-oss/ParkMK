<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/park_gray">

    <!-- Navy header -->
    <LinearLayout android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/park_navy"
        android:orientation="vertical"
        android:padding="16dp">

        <LinearLayout android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="14dp">
            <ImageButton android:id="@+id/btnBack"
                android:layout_width="32dp" android:layout_height="32dp"
                android:background="#20FFFFFF"
                android:src="@drawable/ic_arrow_back"
                android:tint="@color/white"
                android:contentDescription="Back" />
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical"
                android:layout_marginStart="10dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="@string/active_title"
                    android:textColor="@color/white"
                    android:textSize="16sp" android:textStyle="bold" />
                <TextView android:id="@+id/tvSpotName"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:textColor="#80FFFFFF" android:textSize="12sp" />
            </LinearLayout>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="@string/active_live_badge"
                android:textColor="@color/park_green"
                android:textSize="11sp" android:textStyle="bold" />
        </LinearLayout>

        <!-- Timer card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="#12FFFFFF"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp">
            <LinearLayout android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp"
                android:gravity="center">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="@string/active_parked_label"
                    android:textColor="#70FFFFFF"
                    android:textSize="11sp"
                    android:layout_marginBottom="6dp" />
                <TextView android:id="@+id/tvTimer"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="00:00:00"
                    android:textColor="@color/white"
                    android:textSize="44sp"
                    android:fontFamily="monospace"
                    android:layout_marginBottom="4dp" />
                <TextView android:id="@+id/tvCost"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="0.00 ден"
                    android:textColor="@color/park_red"
                    android:textSize="22sp" android:textStyle="bold"
                    android:layout_marginBottom="4dp" />
                <TextView android:id="@+id/tvTimerStatus"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:textColor="#50FFFFFF" android:textSize="12sp" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>
    </LinearLayout>

    <!-- Body -->
    <ScrollView android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">
        <LinearLayout android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Info card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="14dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@color/white"
                android:layout_marginBottom="4dp">
                <LinearLayout android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- Возило - КЛИКАБИЛНО -->
                    <LinearLayout
                        android:id="@+id/rowVehicle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:paddingHorizontal="14dp"
                        android:paddingVertical="11dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:background="?attr/selectableItemBackground">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Возило"
                            android:textSize="12sp"
                            android:textColor="@color/park_text_secondary" />
                        <TextView android:id="@+id/tvVehicleVal"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:textSize="13sp" android:textStyle="bold"
                            android:textColor="@color/park_red" />
                        <ImageView
                            android:layout_width="14dp"
                            android:layout_height="14dp"
                            android:src="@drawable/ic_arrow_back"
                            android:rotation="180"
                            android:tint="@color/park_red"
                            android:layout_marginStart="6dp"
                            android:layout_gravity="center_vertical"
                            android:contentDescription="Избери возило" />
                    </LinearLayout>

                    <View android:layout_width="match_parent" android:layout_height="0.5dp"
                        android:background="@color/park_border" />

                    <!-- Зона -->
                    <LinearLayout android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:paddingHorizontal="14dp"
                        android:paddingVertical="11dp">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Зона"
                            android:textSize="12sp" android:textColor="@color/park_text_secondary" />
                        <TextView android:id="@+id/tvZoneVal"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:textSize="13sp" android:textStyle="bold"
                            android:textColor="@color/park_navy" />
                    </LinearLayout>

                    <View android:layout_width="match_parent" android:layout_height="0.5dp"
                        android:background="@color/park_border" />

                    <!-- Тарифа -->
                    <LinearLayout android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:paddingHorizontal="14dp"
                        android:paddingVertical="11dp">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Тарифа"
                            android:textSize="12sp" android:textColor="@color/park_text_secondary" />
                        <TextView android:id="@+id/tvRateVal"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:textSize="13sp" android:textStyle="bold"
                            android:textColor="@color/park_navy" />
                    </LinearLayout>

                    <View android:layout_width="match_parent" android:layout_height="0.5dp"
                        android:background="@color/park_border" />

                    <!-- Почеток -->
                    <LinearLayout android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:paddingHorizontal="14dp"
                        android:paddingVertical="11dp">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Почеток"
                            android:textSize="12sp" android:textColor="@color/park_text_secondary" />
                        <TextView android:id="@+id/tvStartVal"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:textSize="13sp" android:textStyle="bold"
                            android:textColor="@color/park_navy" />
                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Hint -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="↑ Кликни на возилото за да го промениш"
                android:textColor="@color/park_text_tertiary"
                android:textSize="11sp"
                android:gravity="center"
                android:layout_marginBottom="12dp"
                android:layout_marginTop="4dp" />

            <!-- SMS Box -->
            <LinearLayout android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#E8F4FD"
                android:orientation="vertical"
                android:padding="14dp"
                android:layout_marginBottom="12dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="ИСПРАТИ SMS ЗА АКТИВИРАЊЕ"
                    android:textColor="#2980B9" android:textSize="10sp"
                    android:layout_marginBottom="8dp" />
                <LinearLayout android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@color/park_navy"
                    android:padding="12dp">
                    <TextView android:id="@+id/tvSmsZone"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:textColor="@color/park_yellow"
                        android:textSize="18sp" android:textStyle="bold" />
                    <TextView android:id="@+id/tvSmsPlate"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:textColor="@color/white"
                        android:textSize="18sp" android:textStyle="bold"
                        android:layout_marginStart="4dp" />
                </LinearLayout>
                <TextView android:id="@+id/tvSmsTo"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:textColor="#2980B9" android:textSize="11sp"
                    android:layout_marginTop="6dp" />
            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSendSms"
                android:layout_width="match_parent" android:layout_height="52dp"
                android:layout_marginBottom="10dp"
                android:backgroundTint="@color/park_red"
                android:text="@string/active_send_sms"
                android:textColor="@color/white" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnStop"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="match_parent" android:layout_height="50dp"
                android:text="@string/active_stop"
                android:textColor="@color/park_red"
                app:strokeColor="@color/park_red" />

        </LinearLayout>
    </ScrollView>
</LinearLayout>