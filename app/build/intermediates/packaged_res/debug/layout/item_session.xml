<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardCornerRadius="14dp"
    app:cardElevation="0dp"
    app:cardBackgroundColor="@color/white"
    android:layout_marginBottom="12dp">

    <LinearLayout android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Spot + Cost -->
        <LinearLayout android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical">
                <TextView android:id="@+id/tvSessionSpot"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:textSize="15sp" android:textStyle="bold"
                    android:textColor="@color/park_navy" />
                <TextView android:id="@+id/tvSessionZone"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:textSize="12sp" android:textColor="@color/park_text_secondary" />
            </LinearLayout>
            <TextView android:id="@+id/tvSessionCost"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:textSize="18sp" android:textStyle="bold"
                android:textColor="@color/park_green" />
        </LinearLayout>

        <View android:layout_width="match_parent" android:layout_height="0.5dp"
            android:background="@color/park_border" android:layout_marginBottom="8dp" />

        <!-- Возило -->
        <LinearLayout android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="4dp">
            <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Возило"
                android:textSize="12sp" android:textColor="@color/park_text_secondary" />
            <TextView android:id="@+id/tvSessionPlate"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:textSize="13sp" android:textStyle="bold"
                android:textColor="@color/park_navy" />
        </LinearLayout>

        <!-- Траење -->
        <LinearLayout android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="4dp">
            <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Траење"
                android:textSize="12sp" android:textColor="@color/park_text_secondary" />
            <TextView android:id="@+id/tvSessionDur"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:textSize="13sp" android:textStyle="bold"
                android:textColor="@color/park_navy" />
        </LinearLayout>

        <!-- Почеток -->
        <LinearLayout android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="4dp">
            <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Почеток"
                android:textSize="12sp" android:textColor="@color/park_text_secondary" />
            <TextView android:id="@+id/tvSessionStart"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:textSize="12sp" android:textColor="@color/park_navy" />
        </LinearLayout>

        <!-- Крај -->
        <LinearLayout android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="4dp">
            <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Крај"
                android:textSize="12sp" android:textColor="@color/park_text_secondary" />
            <TextView android:id="@+id/tvSessionEnd"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:textSize="12sp" android:textColor="@color/park_navy" />
        </LinearLayout>

        <!-- SMS -->
        <LinearLayout android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">
            <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="SMS"
                android:textSize="12sp" android:textColor="@color/park_text_secondary" />
            <TextView android:id="@+id/tvSessionSms"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:textSize="12sp" android:textColor="@color/park_red" />
        </LinearLayout>

    </LinearLayout>
</androidx.cardview.widget.CardView>