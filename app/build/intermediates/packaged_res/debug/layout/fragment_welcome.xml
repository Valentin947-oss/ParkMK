<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FF1A1A2E"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:padding="28dp">

        <!-- Logo -->
        <ImageView
            android:layout_width="88dp"
            android:layout_height="88dp"
            android:src="@drawable/ic_parking"
            android:tint="@color/park_red"
            android:contentDescription="ParkMK"
            android:layout_marginTop="40dp"
            android:layout_marginBottom="12dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ПаркМК"
            android:textColor="@color/white"
            android:textSize="30sp"
            android:textStyle="bold"
            android:layout_marginBottom="6dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Битола · паркирање по минута"
            android:textColor="#80FFFFFF"
            android:textSize="14sp"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SMS на 144414"
            android:textColor="#50FFFFFF"
            android:textSize="13sp"
            android:layout_marginBottom="48dp" />

        <!-- Create Account -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnRegister"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:backgroundTint="@color/park_red"
            android:text="Создај профил"
            android:textColor="@color/white"
            android:textSize="15sp"
            android:layout_marginBottom="12dp" />

        <!-- Sign In -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnLogin"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="Влези со е-пошта"
            android:textColor="@color/white"
            android:textSize="15sp"
            android:layout_marginBottom="20dp"
            app:strokeColor="#60FFFFFF" />

        <!-- Divider -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="20dp">
            <View android:layout_width="0dp" android:layout_height="0.5dp"
                android:layout_weight="1" android:background="#30FFFFFF" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="или продолжи со"
                android:textColor="#50FFFFFF" android:textSize="12sp"
                android:layout_marginHorizontal="12dp" />
            <View android:layout_width="0dp" android:layout_height="0.5dp"
                android:layout_weight="1" android:background="#30FFFFFF" />
        </LinearLayout>

        <!-- Google -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnGoogle"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:text="  Продолжи со Google"
            android:textColor="@color/white"
            android:textSize="14sp"
            android:layout_marginBottom="10dp"
            app:icon="@drawable/ic_google"
            app:iconTint="@null"
            app:strokeColor="#40FFFFFF" />

        <!-- Facebook -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnFacebook"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:text="  Продолжи со Facebook"
            android:textColor="@color/white"
            android:textSize="14sp"
            android:layout_marginBottom="10dp"
            app:icon="@drawable/ic_facebook"
            app:iconTint="@null"
            app:strokeColor="#40FFFFFF" />

        <!-- Anonymous -->
        <TextView
            android:id="@+id/btnAnonymous"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Продолжи без профил →"
            android:textColor="#50FFFFFF"
            android:textSize="13sp"
            android:padding="8dp"
            android:layout_marginTop="8dp" />

    </LinearLayout>
</ScrollView>